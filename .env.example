# ─────────────────────────────────────────────────────────────
# Pousinox Bot — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA suba o arquivo .env para o GitHub.
# ─────────────────────────────────────────────────────────────

# ── Z-API (WhatsApp) ──────────────────────────────────────────
ZAPI_INSTANCE_ID=
ZAPI_INSTANCE_TOKEN=
ZAPI_CLIENT_TOKEN=

# ── PagBank (link de pagamento) ───────────────────────────────
PAGBANK_URL=https://pagseguro.uol.com.br/checkout/v2/payment.html?code=SEU_CODE_AQUI

# ── Frete ─────────────────────────────────────────────────────
# CEP de origem da Pousinox (Pouso Alegre / MG)
POUSINOX_ORIGIN_CEP=37550000

# Token Melhor Envio (opcional — sem ele o bot responde "frete manual")
MELHOR_ENVIO_TOKEN=

# ── N8N ──────────────────────────────────────────────────────
N8N_PORT=5678
N8N_HOST=0.0.0.0
N8N_PROTOCOL=https
# Domínio onde o N8N está exposto (ex: n8n.seudominio.com.br)
N8N_EDITOR_BASE_URL=https://n8n.seudominio.com.br
WEBHOOK_URL=https://n8n.seudominio.com.br

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
# Deixe em branco se não usar senha no Redis
REDIS_PASSWORD=

# ── Segurança N8N ─────────────────────────────────────────────
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=TROQUE_ESTA_SENHA

# Chave de criptografia dos dados do N8N (gere com: openssl rand -hex 32)
N8N_ENCRYPTION_KEY=
